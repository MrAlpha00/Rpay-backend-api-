# Razorpay Configuration
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Webhook Secret (optional for development)
# Generate this in Razorpay Dashboard > Webhooks
# This is required for the /api/webhook endpoint to verify webhook authenticity
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Allowed CORS Origins
# Comma-separated list of frontend URLs that can access this API
# Use * for development, but specify actual domains in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend.com

# Allow credentials (cookies, authorization headers)
# Set to 'true' if you need to send cookies or auth headers
ALLOW_CREDENTIALS=false

# Rate Limiting (optional)
# Maximum requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# Window size in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Logging Level (optional)
# Options: debug, info, warn, error
LOG_LEVEL=info
